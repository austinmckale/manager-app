generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  WORKER
}

enum JobStatus {
  LEAD
  ESTIMATE
  SCHEDULED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  PAID
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
}

enum ChangeOrderStatus {
  DRAFT
  SENT
  APPROVED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ExpenseCategory {
  MATERIALS
  SUBCONTRACTOR
  PERMIT
  EQUIPMENT
  MISC
}

enum FileType {
  PHOTO
  VIDEO
  DOCUMENT
  RECEIPT
}

enum FileStage {
  BEFORE
  DURING
  AFTER
}

enum ShareLinkType {
  TIMELINE
  GALLERY
}

enum AuditEntityType {
  ESTIMATE
  CHANGE_ORDER
  INVOICE
}

enum KpiPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum LeadSource {
  WEBSITE_FORM
  PHONE_CALL
  TEXT
  REFERRAL
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  SITE_VISIT_SET
  ESTIMATE_SENT
  WON
  LOST
}

enum LineItemType {
  LABOR
  MATERIAL
  SUBCONTRACT
  PERMIT
  OTHER
}

model Organization {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          UserProfile[]
  customers      Customer[]
  jobs           Job[]
  leads          Lead[]
  kpiTargets     KpiTarget[]
  settings       OrganizationSetting?
}

model OrganizationSetting {
  id                            String       @id @default(uuid()) @db.Uuid
  orgId                         String       @unique @db.Uuid
  workerCanEditOwnTimeSameDay   Boolean      @default(true)
  gpsTimeTrackingEnabled        Boolean      @default(false)
  defaultClockInTime            String       @default("07:00")
  clockGraceMinutes             Int          @default(10)
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt
  organization                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id                 String         @id @db.Uuid
  orgId              String         @db.Uuid
  fullName           String
  email              String
  phone              String?
  role               Role           @default(WORKER)
  isActive           Boolean        @default(true)
  hourlyRateDefault  Decimal?       @db.Decimal(10, 2)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  organization       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedTasks      Task[]
  timeEntries        TimeEntry[]
  activityLogs       ActivityLog[]  @relation("ActivityActor")
  auditLogs          AuditLog[]     @relation("AuditActor")
  shareLinksCreated  ShareLink[]    @relation("ShareLinkCreator")
  portalLinksCreated PortalLink[]   @relation("PortalLinkCreator")
  jobAssignments     JobAssignment[]

  @@index([orgId])
  @@unique([orgId, email])
}

model Customer {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @db.Uuid
  name        String
  phone       String?
  email       String?
  addresses   Json?
  notes       String?
  leadSource  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobs        Job[]
  leads       Lead[]
  portalLinks PortalLink[]

  @@index([orgId])
  @@index([name])
}

model Job {
  id                String        @id @default(uuid()) @db.Uuid
  orgId             String        @db.Uuid
  customerId        String        @db.Uuid
  jobName           String
  address           String
  status            JobStatus     @default(LEAD)
  categoryTags      String[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  startDate         DateTime?
  endDate           DateTime?
  estimatedLaborBudget    Decimal? @db.Decimal(12, 2)
  estimatedMaterialsBudget Decimal? @db.Decimal(12, 2)
  estimatedTotalBudget    Decimal? @db.Decimal(12, 2)
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization      Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  estimates         Estimate[]
  changeOrders      ChangeOrder[]
  timeEntries       TimeEntry[]
  expenses          Expense[]
  tasks             Task[]
  invoices          Invoice[]
  fileAssets        FileAsset[]
  activityLogs      ActivityLog[]
  shareLinks        ShareLink[]
  portalLinks       PortalLink[]
  portalMessages    PortalMessage[]
  leads             Lead[]
  assignments       JobAssignment[]
  scheduleEvents    JobScheduleEvent[]

  @@index([orgId])
  @@index([status])
  @@index([customerId])
}

model Lead {
  id            String       @id @default(uuid()) @db.Uuid
  orgId         String       @db.Uuid
  customerId    String?      @db.Uuid
  jobId         String?      @db.Uuid
  contactName   String
  phone         String?
  email         String?
  address       String?
  serviceType   String?
  source        LeadSource   @default(OTHER)
  stage         LeadStage    @default(NEW)
  externalRef   String?
  rawPayload    Json?
  notes         String?
  lostReason    String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  landingPath   String?
  convertedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([stage])
  @@index([source])
  @@index([createdAt])
  @@index([utmSource])
  @@unique([orgId, externalRef])
}

model JobAssignment {
  id        String      @id @default(uuid()) @db.Uuid
  orgId     String      @db.Uuid
  jobId     String      @db.Uuid
  userId    String      @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  job       Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([jobId])
  @@index([userId])
  @@unique([jobId, userId])
}

model JobScheduleEvent {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  jobId     String   @db.Uuid
  startAt   DateTime
  endAt     DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([jobId])
  @@index([startAt])
  @@index([orgId, startAt])
}

model Estimate {
  id          String         @id @default(uuid()) @db.Uuid
  jobId       String         @db.Uuid
  tax         Decimal        @default(0) @db.Decimal(12, 2)
  margin      Decimal        @default(0) @db.Decimal(12, 2)
  subtotal    Decimal        @default(0) @db.Decimal(12, 2)
  total       Decimal        @default(0) @db.Decimal(12, 2)
  status      EstimateStatus @default(DRAFT)
  sentAt      DateTime?
  approvedAt  DateTime?
  version     Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  job         Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lineItems   EstimateLineItem[]
  invoices    Invoice[]

  @@index([jobId])
  @@index([status])
}

model EstimateLineItem {
  id          String       @id @default(uuid()) @db.Uuid
  estimateId  String       @db.Uuid
  type        LineItemType
  description String
  quantity    Decimal      @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal      @default(0) @db.Decimal(12, 2)
  total       Decimal      @default(0) @db.Decimal(12, 2)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  estimate    Estimate     @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model ChangeOrder {
  id          String            @id @default(uuid()) @db.Uuid
  jobId       String            @db.Uuid
  description String
  total       Decimal           @default(0) @db.Decimal(12, 2)
  status      ChangeOrderStatus @default(DRAFT)
  sentAt      DateTime?
  approvedAt  DateTime?
  version     Int               @default(1)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lineItems   ChangeOrderLineItem[]

  @@index([jobId])
  @@index([status])
}

model ChangeOrderLineItem {
  id             String       @id @default(uuid()) @db.Uuid
  changeOrderId  String       @db.Uuid
  type           LineItemType
  description    String
  quantity       Decimal      @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal      @default(0) @db.Decimal(12, 2)
  total          Decimal      @default(0) @db.Decimal(12, 2)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  changeOrder    ChangeOrder  @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)

  @@index([changeOrderId])
}

model TimeEntry {
  id                  String      @id @default(uuid()) @db.Uuid
  jobId               String      @db.Uuid
  workerId            String      @db.Uuid
  date                DateTime
  start               DateTime
  end                 DateTime?
  breakMinutes        Int         @default(0)
  hourlyRateLoaded    Decimal     @db.Decimal(10, 2)
  notes               String?
  startLat            Decimal?    @db.Decimal(9, 6)
  startLng            Decimal?    @db.Decimal(9, 6)
  endLat              Decimal?    @db.Decimal(9, 6)
  endLng              Decimal?    @db.Decimal(9, 6)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  job                 Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker              UserProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  attachments         FileAsset[]

  @@index([jobId])
  @@index([workerId])
  @@index([date])
}

model Expense {
  id          String          @id @default(uuid()) @db.Uuid
  jobId       String          @db.Uuid
  vendor      String
  category    ExpenseCategory @default(MISC)
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  job         Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  receipt     FileAsset?

  @@index([jobId])
  @@index([category])
  @@index([date])
  @@index([jobId, createdAt])
}

model Task {
  id          String      @id @default(uuid()) @db.Uuid
  jobId       String      @db.Uuid
  assignedTo  String?     @db.Uuid
  title       String
  dueDate     DateTime?
  status      TaskStatus  @default(TODO)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  assignee    UserProfile? @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  photos      FileAsset[]

  @@index([jobId])
  @@index([assignedTo])
  @@index([status])
  @@index([jobId, status, dueDate])
}

model Invoice {
  id                String        @id @default(uuid()) @db.Uuid
  jobId             String        @db.Uuid
  basedOnEstimateId String?       @db.Uuid
  subtotal          Decimal       @default(0) @db.Decimal(12, 2)
  tax               Decimal       @default(0) @db.Decimal(12, 2)
  total             Decimal       @default(0) @db.Decimal(12, 2)
  dueDate           DateTime?
  status            InvoiceStatus @default(DRAFT)
  sentAt            DateTime?
  paidAt            DateTime?
  version           Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  job               Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  basedOnEstimate   Estimate?     @relation(fields: [basedOnEstimateId], references: [id], onDelete: SetNull)
  lineItems         InvoiceLineItem[]
  payments          Payment[]

  @@index([jobId])
  @@index([status])
}

model InvoiceLineItem {
  id          String       @id @default(uuid()) @db.Uuid
  invoiceId   String       @db.Uuid
  type        LineItemType
  description String
  quantity    Decimal      @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal      @default(0) @db.Decimal(12, 2)
  total       Decimal      @default(0) @db.Decimal(12, 2)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id         String    @id @default(uuid()) @db.Uuid
  invoiceId  String    @db.Uuid
  amount     Decimal   @db.Decimal(12, 2)
  date       DateTime
  method     String
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  invoice    Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([date])
}

model FileAsset {
  id               String     @id @default(uuid()) @db.Uuid
  jobId            String     @db.Uuid
  expenseId        String?    @unique @db.Uuid
  timeEntryId      String?    @db.Uuid
  taskId           String?    @db.Uuid
  derivedFromAssetId String?  @db.Uuid
  type             FileType
  storageKey       String
  fileName         String
  mimeType         String?
  fileSize         Int?
  takenAt          DateTime?
  stage            FileStage?
  area             String?
  tags             String[]
  description      String?
  isPortfolio      Boolean    @default(false)
  isClientVisible  Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  job              Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  expense          Expense?   @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  timeEntry        TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  task             Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  derivedFrom      FileAsset? @relation("AssetDerivatives", fields: [derivedFromAssetId], references: [id], onDelete: SetNull)
  derivatives      FileAsset[] @relation("AssetDerivatives")

  @@index([jobId])
  @@index([type])
  @@index([isPortfolio])
  @@index([isClientVisible])
}

model ActivityLog {
  id          String      @id @default(uuid()) @db.Uuid
  orgId       String      @db.Uuid
  jobId       String?     @db.Uuid
  actorId     String?     @db.Uuid
  action      String
  metadata    Json?
  createdAt   DateTime    @default(now())
  job         Job?        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  actor       UserProfile? @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([jobId])
  @@index([createdAt])
}

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  orgId       String         @db.Uuid
  entityType  AuditEntityType
  entityId    String         @db.Uuid
  actorId     String?        @db.Uuid
  event       String
  payload     Json
  createdAt   DateTime       @default(now())
  actor       UserProfile?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ShareLink {
  id               String        @id @default(uuid()) @db.Uuid
  orgId            String        @db.Uuid
  jobId            String        @db.Uuid
  type             ShareLinkType
  token            String        @unique
  selectedAssetIds String[]
  createdBy        String?       @db.Uuid
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())
  job              Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  creator          UserProfile?  @relation("ShareLinkCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([jobId])
}

model PortalLink {
  id          String       @id @default(uuid()) @db.Uuid
  orgId       String       @db.Uuid
  jobId       String       @db.Uuid
  customerId  String       @db.Uuid
  token       String       @unique
  createdBy   String?      @db.Uuid
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  creator     UserProfile? @relation("PortalLinkCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([jobId])
  @@index([customerId])
}

model PortalMessage {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @db.Uuid
  jobId      String    @db.Uuid
  senderName String
  senderEmail String?
  message    String
  createdAt  DateTime  @default(now())
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([jobId])
  @@index([createdAt])
}

model Kpi {
  kpiKey       String      @id
  name         String
  description  String?
  unit         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  targets      KpiTarget[]
}

model KpiTarget {
  id            String       @id @default(uuid()) @db.Uuid
  orgId         String       @db.Uuid
  kpiKey        String
  targetValue   Decimal      @db.Decimal(12, 2)
  period        KpiPeriod
  effectiveDate DateTime
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  kpi           Kpi          @relation(fields: [kpiKey], references: [kpiKey], onDelete: Cascade)

  @@index([orgId])
  @@index([kpiKey])
  @@index([effectiveDate])
  @@unique([orgId, kpiKey, period, effectiveDate])
}
