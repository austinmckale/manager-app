# Transaction mode (port 6543) for app runtime — avoids "max clients" in session mode. pgbouncer=true required for Prisma.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=3"
# Session mode (port 5432) for migrations only — do not use for app traffic.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_APP_URL="https://app.rhipros.com"
NEXT_PUBLIC_QUICKBOOKS_URL="https://app.qbo.intuit.com/app/homepage"
SUPABASE_STORAGE_BUCKET="job-assets"
LEAD_INGEST_API_KEY=""
DEFAULT_ORG_ID="00000000-0000-0000-0000-000000000001"
LEAD_INGEST_ALLOWED_ORIGINS="https://rhipros.com,https://www.rhipros.com"
AUTH_REQUIRED="0"
ATTENDANCE_REMINDER_WEBHOOK_URL=""

# GA4 Measurement Protocol (server-side conversion tracking)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# rhipros-site webhook revalidation (called after portfolio publish)
SITE_REVALIDATE_URL="https://rhipros.com/api/revalidate"
SITE_REVALIDATE_SECRET=""
